{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "sourceMap": true
  },
  "include": [
    "*.ts",
    "pipeline/**/*.ts",
    "routes/**/*.ts",
    "eval/**/*.ts",
    "ai/**/*.ts",
    "../game/src/ecs/**/*.ts",
    "../game/src/ai/**/*.ts",
    "../game/src/assets/**/*.ts"
  ]
}
